<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Etkinlik Sistemi</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EventReservationMVC.styles.css" asp-append-version="true" />
</head>

<body style="background-color: #f4f6f9;">

    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom shadow-sm mb-4">
            <div class="container-fluid">

                <a class="navbar-brand fw-bold text-primary" href="/">
                    Etkinlik Sistemi
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Menüyü Aç/Kapat">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    <ul class="navbar-nav flex-grow-1">

                        <li class="nav-item">
                            <a class="nav-link text-dark fw-semibold" href="/">
                                Ana Sayfa
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark fw-semibold" href="/Categories/Index">
                                Kategoriler
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark fw-semibold" href="/Venues/Index">
                                Mekanlar
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark fw-semibold" href="/Events/Index">
                                Etkinlikler
                            </a>
                        </li>

                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid px-4">
        <main role="main" class="pb-4">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-white mt-5">
        <div class="container text-center py-3">
            &copy; 2026 - Etkinlik Yönetim Sistemi
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>