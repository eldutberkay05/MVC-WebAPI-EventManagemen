@model List<EventReservationMVC.Dtos.CategoryDto>
@{
    ViewData["Title"] = "Kategoriler";
}

<div class="container mt-4">

    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-header text-white rounded-top-4" style="background: linear-gradient(135deg, #6f42c1, #0d6efd);">
            <div class="d-flex justify-content-between align-items-center">
                <h3 class="mb-0">Kategori Listesi</h3>
                <a href="/Categories/Create" class="btn btn-light fw-bold">
                    + Yeni Kategori
                </a>
            </div>
        </div>

        <div class="card-body">

            <form method="get" class="mb-3">
                <div class="input-group">
                    <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Kategori ara..." />
                    <button type="submit" class="btn btn-primary">Ara</button>
                    <a href="/Categories/Index" class="btn btn-secondary">Temizle</a>
                </div>
            </form>

            <table class="table table-hover table-bordered align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Kategori Adı</th>
                        <th style="width: 200px;">İşlemler</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.CategoryId</td>
                            <td>@item.CategoryName</td>
                            <td>
                                <a href="/Categories/Edit/@item.CategoryId" class="btn btn-warning btn-sm">
                                    Güncelle
                                </a>

                                <a href="/Categories/Delete/@item.CategoryId"
                                   class="btn btn-danger btn-sm"
                                   onclick="return confirm('Bu kategoriyi silmek istediğine emin misin?');">
                                    Sil
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>

</div>