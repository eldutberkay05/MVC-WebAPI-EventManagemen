@model EventReservationMVC.Dtos.CategoryDto

@{
    ViewData["Title"] = "Kategori Güncelle";
}

<div class="container mt-4">

    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-header text-dark rounded-top-4" style="background: linear-gradient(135deg, #ffc107, #fd7e14);">
            <h3 class="mb-0">Kategori Güncelle</h3>
        </div>

        <div class="card-body">

            <form method="post">

                <input type="hidden" asp-for="CategoryId" />

                <div class="mb-3">
                    <label class="form-label">Kategori Adı</label>
                    <input asp-for="CategoryName" class="form-control" />
                </div>

                <button type="submit" class="btn btn-warning">Güncelle</button>
                <a href="/Categories/Index" class="btn btn-secondary">Geri Dön</a>

            </form>

        </div>
    </div>

</div>