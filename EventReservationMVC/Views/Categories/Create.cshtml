@model EventReservationMVC.Dtos.CategoryDto

@{
    ViewData["Title"] = "Kategori Ekle";
}

<div class="container mt-4">

    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-header text-white rounded-top-4" style="background: linear-gradient(135deg, #198754, #20c997);">
            <h3 class="mb-0">Yeni Kategori Ekle</h3>
        </div>

        <div class="card-body">

            <form method="post">

                <div class="mb-3">
                    <label class="form-label">Kategori Adı</label>
                    <input asp-for="CategoryName" class="form-control" placeholder="Örn: Konser, Tiyatro, Workshop" />
                </div>

                <button type="submit" class="btn btn-success">Kaydet</button>
                <a href="/Categories/Index" class="btn btn-secondary">Geri Dön</a>

            </form>

        </div>
    </div>

</div>