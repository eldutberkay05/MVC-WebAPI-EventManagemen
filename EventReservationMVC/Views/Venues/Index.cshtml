@model List<EventReservationMVC.Dtos.VenueDto>

@{
    ViewData["Title"] = "Mekanlar";
}

<div class="container mt-4">

    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-header text-white rounded-top-4" style="background: linear-gradient(135deg, #0d6efd, #6610f2);">
            <div class="d-flex justify-content-between align-items-center">
                <h3 class="mb-0">Mekan Listesi</h3>

                <a href="/Venues/Create" class="btn btn-light fw-bold">
                    + Yeni Mekan
                </a>
            </div>
        </div>

        <div class="card-body">

            <form method="get" class="mb-3">
                <div class="input-group">
                    <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Mekan veya konum ara..." />
                    <button type="submit" class="btn btn-primary">Ara</button>
                    <a href="/Venues/Index" class="btn btn-secondary">Temizle</a>
                </div>
            </form>

            <table class="table table-hover table-bordered align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Mekan Adı</th>
                        <th>Konum</th>
                        <th>Kapasite</th>
                        <th style="width: 200px;">İşlemler</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.VenueId</td>
                            <td>@item.VenueName</td>
                            <td>@item.Location</td>
                            <td>@item.Capacity</td>
                            <td>
                                <a href="/Venues/Edit/@item.VenueId" class="btn btn-warning btn-sm">
                                    Güncelle
                                </a>

                                <a href="/Venues/Delete/@item.VenueId"
                                   class="btn btn-danger btn-sm"
                                   onclick="return confirm('Bu mekanı silmek istediğine emin misin?');">
                                    Sil
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>

</div>