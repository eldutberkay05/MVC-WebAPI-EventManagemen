@model List<EventReservationMVC.Dtos.EventDto>

@{
    ViewData["Title"] = "Etkinlikler";
}

<div class="container mt-4">

    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-header text-white rounded-top-4" style="background: linear-gradient(135deg, #dc3545, #fd7e14);">
            <div class="d-flex justify-content-between align-items-center">
                <h3 class="mb-0">Etkinlik Listesi</h3>

                <a href="/Events/Create" class="btn btn-light fw-bold">
                    + Yeni Etkinlik
                </a>
            </div>
        </div>

        <div class="card-body">

            <form method="get" class="mb-3">
                <div class="input-group">
                    <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Etkinlik, kategori veya mekan ara..." />
                    <button type="submit" class="btn btn-primary">Ara</button>
                    <a href="/Events/Index" class="btn btn-secondary">Temizle</a>
                </div>
            </form>

            <table class="table table-hover table-bordered align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Etkinlik Adı</th>
                        <th>Tarih</th>
                        <th>Bilet Fiyatı</th>
                        <th>Kategori</th>
                        <th>Mekan</th>
                        <th style="width: 200px;">İşlemler</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.EventId</td>
                            <td>@item.EventName</td>
                            <td>@item.EventDate.ToString("dd.MM.yyyy")</td>
                            <td>@item.TicketPrice ₺</td>
                            <td>@item.CategoryName</td>
                            <td>@item.VenueName</td>
                            <td>
                                <a href="/Events/Edit/@item.EventId" class="btn btn-warning btn-sm">
                                    Güncelle
                                </a>

                                <a href="/Events/Delete/@item.EventId"
                                   class="btn btn-danger btn-sm"
                                   onclick="return confirm('Bu etkinliği silmek istediğine emin misin?');">
                                    Sil
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>

</div>